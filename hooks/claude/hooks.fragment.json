{
  "SessionStart": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "__SPECFORGE_BRIDGE__ --platform claude --script session-start.sh --event SessionStart --specforge",
          "timeout": 10
        }
      ]
    }
  ],
  "UserPromptSubmit": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "__SPECFORGE_BRIDGE__ --platform claude --script prompt-intent.sh --event UserPromptSubmit --specforge",
          "timeout": 10
        }
      ]
    }
  ],
  "SubagentStop": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "__SPECFORGE_BRIDGE__ --platform claude --script subagent-stop.sh --event SubagentStop --specforge",
          "timeout": 10
        }
      ]
    }
  ],
  "PostToolUse": [
    {
      "matcher": "Edit|Write",
      "hooks": [
        {
          "type": "command",
          "command": "__SPECFORGE_BRIDGE__ --platform claude --script after-spec-edit.sh --event PostToolUse --specforge",
          "timeout": 10
        }
      ]
    }
  ],
  "Stop": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "__SPECFORGE_BRIDGE__ --platform claude --script session-stop.sh --event Stop --specforge",
          "timeout": 10
        }
      ]
    }
  ]
}
